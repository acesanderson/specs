#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SPECS_DIR="$SCRIPT_DIR/src/specs"
NAS_STORAGE_PATH="/mnt/nas"

MAX_ITERATIONS=5
SPEC_DIR_OVERRIDE=""

usage() {
    cat <<EOF
Usage: ralph run <spec-name> [options]

Options:
  --max-iterations N   Max attempts (default: 5)
  --spec-dir PATH      Override specs directory
  -h, --help           Show this help

Examples:
  ralph run 00-hello-world
  ralph run 01-temp-converter --max-iterations 3
EOF
}

die() { echo "Error: $*" >&2; exit 1; }

parse_args() {
    local cmd=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            run)
                [[ -z "$cmd" ]] || die "unexpected argument: $1"
                cmd="run"
                shift
                ;;
            --max-iterations)
                [[ -n "${2:-}" ]] || die "--max-iterations requires a value"
                MAX_ITERATIONS="$2"
                shift 2
                ;;
            --spec-dir)
                [[ -n "${2:-}" ]] || die "--spec-dir requires a value"
                SPEC_DIR_OVERRIDE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -*)
                die "unknown flag: $1"
                ;;
            *)
                if [[ -z "$cmd" ]]; then
                    die "expected 'run' as first argument"
                fi
                [[ -z "$SPEC_NAME" ]] || die "unexpected argument: $1"
                SPEC_NAME="$1"
                shift
                ;;
        esac
    done

    [[ "$cmd" == "run" ]] || die "expected 'run' subcommand"
    [[ -n "$SPEC_NAME" ]] || die "spec name required"
}

build_prompt() {
    local spec_md="$1"
    local acceptance_sh="$2"
    local iteration="$3"
    local is_project="${4:-false}"
    local failure_output="${5:-}"

    if [[ "$iteration" -eq 1 ]]; then
        if [[ "$is_project" == "true" ]]; then
            cat <<PROMPT
You are a coding agent. Your task is to implement a Python project.

A scaffold directory has been provided with the project skeleton. Read the spec below to understand what to build, and read the acceptance test to understand how you'll be graded.

Fill in the implementation. You may:
- Create new files as needed
- Modify existing scaffold files (e.g. pyproject.toml)
- Add dependencies

After implementing, you're done. Do NOT run the tests yourself.

--- SPEC.md ---
$(cat "$spec_md")

--- acceptance.sh ---
$(cat "$acceptance_sh")
PROMPT
        else
            cat <<PROMPT
You are a coding agent. Your task is to write a single Python file called solution.py.

Read the spec below to understand what the script should do, and read the acceptance test to understand how you'll be graded.

Write solution.py to the current directory. It must:
- Be a single file
- Use \`# /// script\` uv inline metadata for any deps (if needed)
- Be invocable via: uv run solution.py [args]

After writing solution.py, you're done. Do NOT run the tests yourself.

--- SPEC.md ---
$(cat "$spec_md")

--- acceptance.sh ---
$(cat "$acceptance_sh")
PROMPT
        fi
    else
        cat <<PROMPT
Your implementation failed the acceptance test. Here is the output:

--- failure output ---
$failure_output
--- end ---

Fix the issue and try again. Do NOT run the tests yourself.

For reference, here is the spec and acceptance test again:

--- SPEC.md ---
$(cat "$spec_md")

--- acceptance.sh ---
$(cat "$acceptance_sh")
PROMPT
    fi
}

cmd_run() {
    local specs_dir="$SPECS_DIR"
    [[ -n "$SPEC_DIR_OVERRIDE" ]] && specs_dir="$SPEC_DIR_OVERRIDE"

    local spec_dir="$specs_dir/$SPEC_NAME"
    [[ -d "$spec_dir" ]] || die "spec not found: $spec_dir"
    [[ -f "$spec_dir/SPEC.md" ]] || die "SPEC.md not found in $spec_dir"
    [[ -f "$spec_dir/acceptance.sh" ]] || die "acceptance.sh not found in $spec_dir"

    local timestamp
    timestamp=$(date +%Y%m%dT%H%M%S)
    local work_dir
    work_dir=$(mktemp -d)

    local model_name="unknown"
    if [[ -f "$HOME/.custom_functions" ]]; then
        # shellcheck source=~/.custom_functions
        source "$HOME/.custom_functions"
        local active_output
        active_output=$(active 2>/dev/null) || true
        if [[ "$active_output" == no\ model\ loaded* ]]; then
            model_name="unknown"
        else
            model_name=$(echo "$active_output" | sed 's/^[^:]*: //')
        fi
    fi
    local uuid="${SPEC_NAME}_${model_name}_${timestamp}"

    # Copy spec contents (not solution.py)
    cp "$spec_dir/SPEC.md" "$work_dir/"
    cp "$spec_dir/acceptance.sh" "$work_dir/"
    chmod +x "$work_dir/acceptance.sh"
    if [[ -d "$spec_dir/fixtures" ]]; then
        cp -r "$spec_dir/fixtures" "$work_dir/"
    fi
    if [[ -d "$spec_dir/scaffold" ]]; then
        cp -a "$spec_dir/scaffold/." "$work_dir/"
    fi

    local spec_md="$work_dir/SPEC.md"
    local acceptance_sh="$work_dir/acceptance.sh"

    local is_project="false"
    [[ -d "$spec_dir/scaffold" ]] && is_project="true"

    echo "Spec:     $SPEC_NAME"
    echo "Type:     $([ "$is_project" = "true" ] && echo "project" || echo "single-file")"
    echo "Work dir: $work_dir"
    echo ""

    local passed=false
    local last_output=""

    for i in $(seq 1 "$MAX_ITERATIONS"); do
        echo "Iteration $i/$MAX_ITERATIONS — invoking pi..."

        local prompt
        if [[ "$i" -eq 1 ]]; then
            prompt=$(build_prompt "$spec_md" "$acceptance_sh" "$i" "$is_project")
        else
            prompt=$(build_prompt "$spec_md" "$acceptance_sh" "$i" "$is_project" "$last_output")
        fi

        # Invoke pi from the working directory with logging
        (cd "$work_dir" && pi -p "$prompt" -nc --no-extensions -a) > "$work_dir/pi_output.log" 2>&1 || true
        
        # Save session data for replay
        if [[ -d ~/.pi/agent/sessions ]]; then
            # Create a timestamped session directory
            SESSION_DIR="$work_dir/session_$(date +%Y%m%d_%H%M%S)"
            mkdir -p "$SESSION_DIR"
            # Copy session data
            cp -r ~/.pi/agent/sessions/* "$SESSION_DIR/" 2>/dev/null || true
        fi

        echo "pi finished. Running acceptance.sh..."

        # Run acceptance test, capture output
        last_output=""
        local exit_code=0
        last_output=$(cd "$work_dir" && bash acceptance.sh 2>&1) || exit_code=$?

        # Print the test output indented
        echo "$last_output" | sed 's/^/  /'
        echo ""

        if [[ "$exit_code" -eq 0 ]]; then
            passed=true
            echo "✓ PASS ($i iteration(s))"
            save_to_nas "$SPEC_NAME" "$model_name" "$timestamp" "$uuid" "$i" "$work_dir" "success" 0 ""
            rm -rf "$work_dir"
            exit 0
        fi
    done

    # All iterations exhausted
    echo "✗ FAIL ($MAX_ITERATIONS iterations exhausted)"

    # Save failed run to NAS
    save_to_nas "$SPEC_NAME" "$model_name" "$timestamp" "$uuid" "$MAX_ITERATIONS" "$work_dir" "failed" "$exit_code" "$last_output"

    # Clean up temp directory
    rm -rf "$work_dir"

    exit 1
}

save_to_nas() {
    local spec_name="$1"
    local model_name="$2"
    local timestamp="$3"
    local uuid="$4"
    local iterations="$5"
    local work_dir="$6"
    local status="$7"
    local exit_code="$8"
    local failure_output="${9:-}"

    local nas_storage_dir="$NAS_STORAGE_PATH/specs/$uuid"
    mkdir -p "$nas_storage_dir"
    mkdir -p "$nas_storage_dir/code"
    mkdir -p "$nas_storage_dir/logs"

    # Save code artifacts
    mkdir -p "$nas_storage_dir/code"
    if [[ -f "$work_dir/solution.py" ]]; then
        cp "$work_dir/solution.py" "$nas_storage_dir/code/"
    fi
    # For project specs, save scaffold tree (excluding spec metadata)
    if [[ -d "$work_dir/scaffold" ]] || [[ -f "$work_dir/pyproject.toml" ]]; then
        for item in "$work_dir"/*; do
            local name
            name=$(basename "$item")
            case "$name" in
                SPEC.md|acceptance.sh|fixtures|solution.py|pi_output.log|session_*) continue ;;
                *) cp -a "$item" "$nas_storage_dir/code/" ;;
            esac
        done
    fi

    # Save session log (full JSONL transcript)
    local session_dir_name
    session_dir_name=$(echo "$work_dir" | sed 's|^/||; s|/|-|g')
    session_dir_name="--${session_dir_name}--"
    local session_dir="$HOME/.pi/agent/sessions/$session_dir_name"
    local session_jsonl=""
    if [[ -d "$session_dir" ]]; then
        session_jsonl=$(ls "$session_dir"/*.jsonl 2>/dev/null | head -1)
    fi
    if [[ -n "$session_jsonl" && -f "$session_jsonl" ]]; then
        cp "$session_jsonl" "$nas_storage_dir/logs/session.log"
    elif [[ -f "$work_dir/pi_output.log" ]]; then
        cp "$work_dir/pi_output.log" "$nas_storage_dir/logs/session.log"
    fi

    # Escape failure output for JSON (newlines and quotes)
    local escaped_output=""
    if [[ -n "$failure_output" ]]; then
        escaped_output=$(printf '%s' "$failure_output" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()), end="")')
    fi

    # Save metadata.json
    local metadata
    metadata=$(python3 -c "
import json, sys
data = {
    'spec_name': sys.argv[1],
    'model_name': sys.argv[2],
    'timestamp': sys.argv[3],
    'status': sys.argv[4],
    'iterations': int(sys.argv[5]),
    'exit_code': int(sys.argv[6])
}
if sys.argv[4] == 'failed' and sys.argv[7]:
    data['failure_output'] = json.loads(sys.argv[7])
print(json.dumps(data, indent=2))
" "$spec_name" "$model_name" "$timestamp" "$status" "$iterations" "$exit_code" "$escaped_output")
    echo "$metadata" > "$nas_storage_dir/metadata.json"

    # Save failure manifest for failed runs
    if [[ "$status" == "failed" ]]; then
        # Save acceptance.log with the last failure output
        echo "$last_output" > "$nas_storage_dir/logs/acceptance.log"

        # Create failure manifest
        local manifest
        manifest=$(python3 -c "
import json, sys
manifest = {
    'spec_name': sys.argv[1],
    'model_name': sys.argv[2],
    'timestamp': sys.argv[3],
    'status': 'failed',
    'iterations_attempted': int(sys.argv[5]),
    'final_exit_code': int(sys.argv[6]),
    'failure_output': sys.argv[7] if sys.argv[7] else '',
    'solution_file': 'code/solution.py',
    'session_log': 'logs/session.log',
    'acceptance_log': 'logs/acceptance.log'
}
print(json.dumps(manifest, indent=2))
" "$spec_name" "$model_name" "$timestamp" "$timestamp" "$iterations" "$exit_code" "$failure_output")
        echo "$manifest" > "$nas_storage_dir/${spec_name}_${model_name}_${timestamp}_failed.json"
    fi

    echo "Artifacts saved to NAS: $nas_storage_dir"
}

# --- main ---

SPEC_NAME=""
parse_args "$@"

cmd_run